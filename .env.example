# Cloudflare Turnstile (anti-spam formulaire de contact)
# Clé publique — exposée côté client
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Clé secrète — serveur uniquement, ne jamais exposer au client
TURNSTILE_SECRET_KEY=

# Destinataire des demandes de contact (env pour l'instant ; BDD plus tard)
CONTACT_TO_EMAIL=
# Expéditeur SMTP (ex. noreply@kyira.local en local)
CONTACT_FROM_EMAIL=

# SMTP — Mailpit en local (UI http://127.0.0.1:8025)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
# Laisser vides pour Mailpit (pas d'auth)
SMTP_USER=
SMTP_PASS=
